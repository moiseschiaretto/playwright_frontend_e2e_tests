{
  "name": "playwright-frontend-e2e-tests",
  "version": "1.0.0",
  "description": "Testes E2E multi-dispositivo (desktop/mobile/tablet responsivo) com Playwright + TypeScript, Page Object Model, contra o SauceDemo (site público estável para prática de automação)",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:desktop": "playwright test --project=desktop",
    "test:mobile": "playwright test --project=mobile",
    "test:tablet": "playwright test --project=tablet",
    "report": "playwright show-report playwright-report",
    "allure:clean": "node -e \"require('fs').rmSync('allure-results',{recursive:true,force:true});require('fs').rmSync('allure-report',{recursive:true,force:true})\"",
    "allure:generate": "npx allure-commandline generate allure-results --clean -o allure-report",
    "allure:open": "npx allure-commandline open allure-report",
    "allure:serve": "npx allure-commandline serve allure-results",
    "test:allure": "npm run allure:clean && npm run test && npm run allure:generate",
    "test:allure:open": "npm run test:allure && npm run allure:open"
  },
  "keywords": ["playwright", "typescript", "e2e", "page-object-model", "qa", "sdet"],
  "author": "Moisés Chiaretto",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/node": "^25.5.0",
    "allure-playwright": "^3.4.3",
    "allure-commandline": "^2.34.0",
    "dotenv": "^17.3.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}